{
  "manifest_version": 2,
  "name": "Copy Clean URL",
  "version": "1.4",
  "browser_specific_settings": {
    "gecko": {
      "id": "copy-clean-url@pavel",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "browser_action": {
    "default_icon": {
      "32": "icon.png"
    }
  },
  "commands": {
    "copy-url": {
      "suggested_key": {
        "default": "Ctrl+Shift+C"
      },
      "description": "Copy clean URL"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "permissions": [
    "activeTab",
    "clipboardWrite"
  ]
}
